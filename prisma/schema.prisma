generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum NovelStatus {
  ONGOING
  COMPLETED
  HIATUS
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())

  accounts           Account[]
  sessions           Session[]
  favorites          Favorite[]
  comments           Comment[]
  progress           ReadingProgress[]
  createdNovels      Novel[]           @relation("NovelCreator")
  tickets            Ticket[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@map("password_reset_tokens")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Genre {
  id     String       @id @default(cuid())
  name   String       @unique
  slug   String       @unique
  novels NovelGenre[]

  @@map("genres")
}

model Novel {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  author      String
  description String
  coverImage  String?
  status      NovelStatus @default(ONGOING)
  views       Int         @default(0)
  createdById String?
  createdBy   User?       @relation("NovelCreator", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  chapters  Chapter[]
  genres    NovelGenre[]
  favorites Favorite[]
  comments  Comment[]
  progress  ReadingProgress[]

  @@map("novels")
}

model NovelGenre {
  novelId String
  genreId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([novelId, genreId])
  @@map("novel_genres")
}

model Chapter {
  id            String   @id @default(cuid())
  novelId       String
  novel         Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterNumber Int
  title         String
  content       String
  views         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  comments Comment[]
  progress ReadingProgress[]

  @@unique([novelId, chapterNumber])
  @@index([novelId])
  @@map("chapters")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterId String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([novelId])
  @@index([chapterId])
  @@map("comments")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, novelId])
  @@map("favorites")
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketType {
  BUG
  FEATURE
  AUTHOR_REQUEST
  NOVEL_REQUEST
  OTHER
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Ticket {
  id        String         @id @default(cuid())
  title     String
  content   String
  type      TicketType     @default(OTHER)
  priority  TicketPriority @default(NORMAL)
  status    TicketStatus   @default(PENDING)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminNote String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

model ReadingProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([userId, novelId])
  @@map("reading_progress")
}
